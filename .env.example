# Copy to .env and fill in. NEVER commit your real .env.

# Required: the ntfy topic to publish to. This is your only secret, so make it
# long and random (e.g. `openssl rand -hex 16`). Subscribe to the same string
# in the ntfy phone app.
NTFY_TOPIC=change-me-to-a-long-random-string

# Optional: base URL of the ntfy server. Default is the public https://ntfy.sh
# Set this to your own host if you self-host ntfy.
NTFY_BASE_URL=https://ntfy.sh

# Optional: bearer access token for protected topics / self-hosted servers.
# Leave blank for public topics on ntfy.sh.
NTFY_TOKEN=
